# Supabase
# If verification emails don't arrive: Supabase Dashboard → Authentication → Providers → Email → turn OFF "Confirm email"
# See docs/SUPABASE_AUTH_EMAIL.md for details.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Railway Backend (server-side API routes use BACKEND_URL, client-side use NEXT_PUBLIC_BACKEND_URL)
BACKEND_URL=https://nortstarai-backend-production.up.railway.app
NEXT_PUBLIC_BACKEND_URL=https://nortstarai-backend-production.up.railway.app

# Anthropic (now handled by backend, but kept for fallback)
ANTHROPIC_API_KEY=sk-ant-...

# App (used as auth redirect base; must match Supabase Redirect URLs, e.g. https://nortstar-ai.vercel.app)
NEXT_PUBLIC_SITE_URL=https://nortstar-ai.vercel.app

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Cron security
CRON_SECRET=your-random-secret

# Optional: OAuth providers
OKTA_DOMAIN=your-company.okta.com
AZURE_AD_TENANT_ID=your-tenant-id
